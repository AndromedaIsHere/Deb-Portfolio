---
import Layout from '../../components/Layout.astro';
import '../../styles/global.css';
import { aiInAction } from '../../data/ai-in-action.js';

export function getStaticPaths() {
  return aiInAction.map((item) => ({
    params: { slug: item.slug },
    props: { item },
  }));
}

const { item } = Astro.props;

const siteUrl = 'https://www.dasdebajyoti.com';
const pageUrl = `${siteUrl}/ai/${item.slug}/`;
const metaDesc = item.metaDescription ?? item.solution;

// Build the TOC from whichever sections exist for this item
const tocItems = [
  { id: 'business-context',        label: 'The business problem I was actually solving',       show: !!item.businessContext },
  //{ id: 'the-problem',             label: 'The problem',             show: true },
  { id: 'user-segmentation',       label: 'The user I focused on — and why',       show: !!item.userSegmentation },
  { id: 'problem-prioritisation',  label: 'The problem worth solving first',  show: !!item.problemPrioritisation },
  { id: 'why-ai',                  label: 'Why AI — and why not something simpler',                 show: !!item.whyAI },
  { id: 'solution-design',        label: 'Product direction',         show: !!item.solutionDesign },
  { id: 'key-decisions',           label: 'Key design decisions',           show: !!item.keyDecisions },
  //{ id: 'technical-architecture',  label: 'Technical architecture',  show: !!item.architecture },
  { id: 'risks',                   label: 'Risks & mitigations',     show: !!item.risks },
  //{ id: 'outcome',                 label: 'Outcome',                 show: true },
  { id: 'metrics',                 label: 'How I\'d measure success', show: !!item.metrics },
  { id: 'what-i-learned',          label: 'What I learned',          show: !!item.learned },
  { id: 'my-role',                 label: 'My role',                 show: true },
  { id: 'technologies',            label: 'Technologies',            show: !!item.technologies },
].filter((t) => t.show);
---

<Layout
  title={`${item.title} — AI Case Study | Debajyoti Das`}
  description={metaDesc}
  type="article"
  imageAlt={`${item.title} — AI product case study by Debajyoti Das`}
>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "BreadcrumbList",
        "itemListElement": [
          { "@type": "ListItem", "position": 1, "name": "Home",         "item": `${siteUrl}/` },
          { "@type": "ListItem", "position": 2, "name": "AI in action", "item": `${siteUrl}/#ai-in-action` },
          { "@type": "ListItem", "position": 3, "name": item.title,     "item": pageUrl }
        ]
      },
      {
        "@type": "Article",
        "headline": item.title,
        "description": metaDesc,
        "author": {
          "@type": "Person",
          "name": "Debajyoti Das",
          "url": siteUrl
        },
        "publisher": {
          "@type": "Person",
          "name": "Debajyoti Das",
          "url": siteUrl
        },
        "mainEntityOfPage": {
          "@type": "WebPage",
          "@id": pageUrl
        }
      }
    ]
  })} />
  <div class="cs-layout">

    <!-- ── Left nav (sticky TOC) ── -->
    <aside class="cs-toc" aria-label="Page contents">
      <p class="cs-toc-back"><a href="/#ai-in-action">← AI in action</a></p>
      <p class="cs-toc-title">{item.title}</p>
      <nav>
        <ul class="cs-toc-list">
          {tocItems.map((t) => (
            <li><a href={`#${t.id}`} class="cs-toc-link">{t.label}</a></li>
          ))}
        </ul>
      </nav>
    </aside>

    <!-- ── Main content ── -->
    <article class="case-study-page">

      <!-- Header -->
      <header class="case-study-page-header">
        <p class="case-study-page-domain">{item.domain}</p>
        <h1 class="case-study-page-title">{item.title}</h1>
        <p class="case-study-page-solution">{item.solution}</p>
      </header>

      <!-- Body -->
      <section class="case-study-page-body cs-editorial">

        {item.businessContext && (
          <div class="cs-section" id="business-context">
            <h2>The business problem</h2>
            {item.businessContext.split('\n\n').map((para) => <p>{para.trim()}</p>)}
          </div>
        )}

        {item.userSegmentation && (
          <div class="cs-section" id="user-segmentation">
            <h2>The user</h2>
            {item.userSegmentation.split('\n\n').map((para) => <p>{para.trim()}</p>)}
          </div>
        )}

        {item.problemPrioritisation && (
          <div class="cs-section" id="problem-prioritisation">
            <h2>The user problem</h2>
            {item.problemPrioritisation.split('\n\n').map((para) => <p>{para.trim()}</p>)}
          </div>
        )}

        {item.whyAI && (
          <div class="cs-section" id="why-ai">
            <h2>Why AI?</h2>
            {item.whyAI.split('\n\n').map((para) => <p>{para.trim()}</p>)}
          </div>
        )}

        {item.solutionDesign && (
          <div class="cs-section" id="solution-design">
            <h2>Product direction</h2>
            {item.solutionDesign.overview && (
              <p>{item.solutionDesign.overview}</p>
            )}
            {item.solutionDesign.steps && item.solutionDesign.steps.map((step) => (
              <div class="cs-decision">
                <p><strong>{step.title}</strong></p>
                {step.detail.split('\n\n').map((para) => <p>{para.trim()}</p>)}
              </div>
            ))}
          </div>
        )}

        {item.keyDecisions && (
          <div class="cs-section" id="key-decisions">
            <h2>Key design decisions</h2>
            {item.keyDecisions.map((d) => (
              <div class="cs-decision">
                <p><strong>{d.decision}</strong></p>
                {d.rationale.split('\n\n').map((para) => <p>{para.trim()}</p>)}
              </div>
            ))}
          </div>
        )}

        {item.architecture && (
          <div class="cs-section" id="technical-architecture">
            <h2>The architecture</h2>
            <p>{item.architecture.overview}</p>
            {item.architecture.layers && item.architecture.layers.map((l) => (
              <div class="cs-arch-block">
                <p class="cs-arch-layer">{l.layer}</p>
                <p>{l.detail}</p>
              </div>
            ))}
            {item.architecture.stackImage ? (
              <div class="cs-arch-image">
                <img
                  src={item.architecture.stackImage}
                  alt="Technical architecture diagram"
                  class="cs-arch-img"
                />
              </div>
            ) : item.architecture.frameworks && (
              <div class="cs-arch-stack">
                <p class="cs-arch-stack-label">Stack</p>
                <ul class="cs-arch-framework-list">
                  {item.architecture.frameworks.map((f) => (
                    <li><strong>{f.name}</strong> — {f.detail}</li>
                  ))}
                </ul>
              </div>
            )}
          </div>
        )}

        {item.risks && (
          <div class="cs-section" id="risks">
            <h2>Risks & mitigations</h2>
            {item.risks.map((r) => (
              <div class="cs-decision">
                <p><strong>{r.risk}</strong></p>
                <p>{r.mitigation}</p>
              </div>
            ))}
          </div>
        )}

        {item.metrics && (
          <div class="cs-section" id="metrics">
            <h2>How I'd measure success</h2>
            <div class="cs-metrics">
              {[
                { label: 'Business',    items: item.metrics.business },
                { label: 'Product',     items: item.metrics.product },
                { label: 'AI-specific', items: item.metrics.ai },
              ].map(({ label, items }) => (
                <div class="cs-metrics-group">
                  <p class="cs-metrics-label">{label}</p>
                  <ul class="cs-metrics-list">
                    {items.map((m) => {
                      const text     = typeof m === 'string' ? m : m.metric;
                      const observed = typeof m === 'string' ? null : m.observed;
                      return (
                        <li class="cs-metrics-item">
                          <span class="cs-metrics-text">{text}</span>
                          {observed && <span class="cs-metrics-observed">{observed}</span>}
                        </li>
                      );
                    })}
                  </ul>
                </div>
              ))}
            </div>
          </div>
        )}

        {item.learned && (
          <div class="cs-section" id="what-i-learned">
            <h2>What I learned</h2>
            {item.learned.map((l) => (
              <div class="cs-learned-item">
                <p><strong>{l.heading}</strong></p>
                {l.body.split('\n\n').map((para) => <p>{para.trim()}</p>)}
              </div>
            ))}
          </div>
        )}

        <div class="cs-section" id="my-role">
          <h2>My role</h2>
          <p>{item.responsibilities.join(' · ')}</p>
        </div>

        {item.technologies && (
          <div class="cs-section" id="technologies">
            <h2>Technologies</h2>
            <div class="case-study-tags">
              {item.technologies.map((tag) => (
                <span class="case-study-tag">{tag}</span>
              ))}
            </div>
          </div>
        )}

        {item.disclaimer && (
          <div class="cs-section cs-disclaimer" id="disclaimer">
            <p><strong>Disclaimer</strong></p>
            <p>{item.disclaimer}</p>
          </div>
        )}

      </section>
    </article>
  </div>

  <!-- Active TOC link highlight via IntersectionObserver -->
  <script is:inline>
    (function () {
      var links = document.querySelectorAll('.cs-toc-link');
      if (!links.length) return;

      var map = {};
      links.forEach(function (a) {
        var id = a.getAttribute('href').slice(1);
        map[id] = a;
      });

      var observer = new IntersectionObserver(function (entries) {
        entries.forEach(function (entry) {
          if (entry.isIntersecting) {
            Object.values(map).forEach(function (a) { a.classList.remove('cs-toc-link--active'); });
            var a = map[entry.target.id];
            if (a) a.classList.add('cs-toc-link--active');
          }
        });
      }, { rootMargin: '-20% 0px -70% 0px' });

      Object.keys(map).forEach(function (id) {
        var el = document.getElementById(id);
        if (el) observer.observe(el);
      });
    })();
  </script>
</Layout>
