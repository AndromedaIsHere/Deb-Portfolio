---
import '../styles/global.css';
import Layout from '../components/Layout.astro';
import { aiInAction } from '../data/ai-in-action.js';

const essays = [
  {
    slug: 'why-ai-roadmaps-fail',
    title: "Why most AI product roadmaps fail before they start",
    category: 'AI Strategy',
    href: '#writing',
  },
  {
    slug: 'discovery-sprint',
    title: "How to run a discovery sprint that actually informs the roadmap",
    category: 'Product',
    href: '#writing',
  },
  {
    slug: 'positioning-ai-skeptics',
    title: "Positioning AI features for buyers who don't trust AI yet",
    category: 'Go-to-Market',
    href: '#writing',
  },
];

const speaking = [
  {
    slug: 'productcon-2025',
    title: "From Experiment to Product: Shipping AI Features at Scale",
    category: 'ProductCon 2025',
    href: '#speaking',
  },
  {
    slug: 'ai-summit-nyc',
    title: "Building Trust in AI-Powered Workflows",
    category: 'AI Summit NYC',
    href: '#speaking',
  },
  {
    slug: 'saastr-annual',
    title: "Metrics That Matter: Measuring AI Product Value",
    category: 'SaaStr Annual',
    href: '#speaking',
  },
];
---

<Layout
  title="Deb | AI Product Manager"
  description="AI Product Manager writing about intelligent products, strategy, and the future of work."
>
  <div class="home">

    <!-- ── Hero ──────────────────────────────────────────── -->
    <section class="hero hero-overview">
      <div class="hero-overview-text">
        <p class="hero-greeting">
          Hey, I'm Deb — an AI Product Manager helping teams ship intelligent products that
          drive real business outcomes.
        </p>
        <p class="hero-intro">
          Over the last several years I've worked across product strategy, customer discovery,
          and go-to-market execution for AI and SaaS products — turning research and market
          signals into clear roadmap bets.
        </p>
        <p class="hero-intro">
          Today I partner with founders and product teams as an advisor, help orgs build
          repeatable AI launch playbooks, and write about what it actually takes to ship AI
          products people trust.
        </p>
        <p class="hero-intro">
          This site is a living notebook of that work — playbooks, field notes, and occasional
          reflections from building at the intersection of product and AI.
        </p>
        <p class="hero-intro hero-about-cta">
          Want to know more? <a href="#about">Read about me here</a>.
        </p>
      </div>

      <!-- Portrait placeholder — replace src with your real photo -->
      <div class="hero-overview-image">
        <img
          src="https://placehold.co/320x400/e8b89a/1a1a1a?text=Deb"
          alt="Deb"
          class="hero-portrait"
          width="320"
          height="400"
        />
      </div>
    </section>

    <!-- ── Latest essays ─────────────────────────────────── -->
    <section id="writing">
      <h2 class="section-title">Latest essays</h2>
      <ul class="notes-list">
        {essays.map((post) => (
          <li class="notes-list-item">
            <a href={post.href}>
              <h3>{post.title}</h3>
            </a>
            <span class="notes-list-meta">
              <span class="notes-list-category">{post.category}</span>
            </span>
          </li>
        ))}
      </ul>
      <p><a href="#writing" class="view-all">View all essays</a></p>
    </section>

    <!-- ── AI in action ──────────────────────────────────── -->
    <section id="ai-in-action">
      <h2 class="section-title">AI in action</h2>
      <p class="section-desc">Six AI products built across enterprise SaaS, life sciences, and fintech.</p>
      <ul class="notes-list">
        {aiInAction.map((item) => (
          <li class="notes-list-item">
            <a href={`/ai/${item.slug}`}>
              <h3>{item.title}</h3>
            </a>
            <span class="notes-list-meta">
              <span class="notes-list-category">{item.domain}</span>
            </span>
          </li>
        ))}
      </ul>
    </section>

    <!-- ── Speaking ──────────────────────────────────────── -->
    <section id="speaking">
      <h2 class="section-title">Speaking</h2>
      <p class="section-desc">Talks, panels, and podcasts on AI product strategy.</p>
      <ul class="notes-list">
        {speaking.map((talk) => (
          <li class="notes-list-item">
            <a href={talk.href}>
              <h3>{talk.title}</h3>
            </a>
            <span class="notes-list-meta">
              <span class="notes-list-category">{talk.category}</span>
            </span>
          </li>
        ))}
      </ul>
      <p><a href="#speaking" class="view-all">View all speaking</a></p>
    </section>

    <!-- ── Connect CTA ───────────────────────────────────── -->
    <section id="about" class="connect-cta" aria-labelledby="connect-cta-title">
      <div class="connect-cta-inner">
        <h2 id="connect-cta-title" class="connect-cta-title">Let's connect</h2>
        <p class="connect-cta-text">
          I'm always up for conversations with founders, builders, and fellow AI-curious
          folks shipping real products. Say hi on LinkedIn.
        </p>
        <a
          href="https://linkedin.com/in/"
          target="_blank"
          rel="noopener noreferrer"
          class="connect-cta-button"
        >
          <svg class="connect-cta-icon" viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" focusable="false">
            <path fill="currentColor" d="M20.45 20.45h-3.56v-5.57c0-1.33-.03-3.04-1.85-3.04-1.86 0-2.14 1.45-2.14 2.94v5.67H9.35V9h3.42v1.56h.05c.48-.9 1.65-1.85 3.39-1.85 3.62 0 4.29 2.38 4.29 5.48v6.26ZM5.34 7.43a2.07 2.07 0 1 1 0-4.14 2.07 2.07 0 0 1 0 4.14Zm1.78 13.02H3.56V9h3.56v11.45ZM22.22 0H1.77C.79 0 0 .77 0 1.72v20.56C0 23.23.79 24 1.77 24h20.45c.98 0 1.78-.77 1.78-1.72V1.72C24 .77 23.2 0 22.22 0Z"></path>
          </svg>
          <span>Connect with me on LinkedIn</span>
          <span class="connect-cta-arrow" aria-hidden="true">→</span>
        </a>
      </div>
    </section>

  </div>
</Layout>
