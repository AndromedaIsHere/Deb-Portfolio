---
import '../styles/global.css';
import Layout from '../components/Layout.astro';
import { aiInAction } from '../data/ai-in-action.js';

const essays = [
  {
    slug: 'why-ai-roadmaps-fail',
    title: "Overcoming new drug launch challenges with AI",
    category: 'AI Strategy',
    href: 'https://www.linkedin.com/posts/activity-7185936813046292480-UhUT?utm_source=share&utm_medium=member_desktop&rcm=ACoAAAfrKH4BZHaJb5cozOgCRlGSGg0KF8V6Dmw',
  },
];

const speaking = [
  {
    slug: 'productcon-2025',
    title: "AI Monetization: Customers don't pay for AI. They pay for Outcomes",
    category: 'Product Leaders Day 2025',
    href: 'https://productleadersdayindia.org/past-events/2025/ai-monetization-ramya-venkatesh.html',
  },
];
---

<Layout
  title="Deb | AI Product Manager"
  description="AI Product Manager writing about intelligent products, strategy, and the future of work."
>
  <div class="home">

    <!-- ── Hero ──────────────────────────────────────────── -->
    <section class="hero hero-overview">
      <div class="hero-overview-text">
        <p class="hero-greeting">
          Hey, I'm Debajyoti — a Senior Product Manager helping teams ship intelligent AI-powered products that
          drive real business outcomes.
        </p>
        <p class="hero-intro">
          I build enterprise products that help organizations make better decisions, automate complex workflows, and unlock measurable business value.
        </p>
        <p class="hero-intro">
          Over the last 6 years, I've led the development and scaling of AI-powered SaaS products across Asset Lifecycle Management, Life Sciences, Banking, Insurance, and Mortgage. My experience spans Coversational AI, decision intelligence, recommendation systems, and intelligent workflow automation—taking products from concept to enterprise adoption.
        </p>
        <p class="hero-intro">
          Currently, I lead AI initiatives at Siemens Brightly, where AI is a strategic investment area focused on improving customer retention, product adoption, and long-term growth. I work closely with customers, executives, data scientists, and engineers to identify high-value AI opportunities and translate emerging technologies into products that solve real business problems.
        </p>
        <p class="hero-intro">
          This site is a living notebook of that work — playbooks, field notes, and occasional
          reflections from building at the intersection of product and AI.
        </p>
        <!-- <p class="hero-intro hero-about-cta">
          Want to know more? <a href="#about">Read about me here</a>.
        </p> -->
      </div>

      <div class="hero-overview-image">
        <img
          src="/20230607_090330.jpg"
          alt="Deb"
          class="hero-portrait"
          width="320"
          height="400"
        />
      </div>
    </section>

    <!-- ── Latest essays ─────────────────────────────────── -->
    <section id="writing">
      <h2 class="section-title">Latest essays</h2>
      <ul class="notes-list">
        {essays.map((post) => (
          <li class="notes-list-item">
            <a href={post.href}>
              <h3>{post.title}</h3>
            </a>
            <span class="notes-list-meta">
              <span class="notes-list-category">{post.category}</span>
            </span>
          </li>
        ))}
      </ul>
      <!-- <p><a href="#writing" class="view-all">View all essays</a></p> -->
    </section>

    <!-- ── AI in action ──────────────────────────────────── -->
    <section id="ai-in-action">
      <h2 class="section-title">AI in action</h2>
      <p class="section-desc">What I've built with AI</p>
      <ul class="notes-list">
        {aiInAction.map((item) => (
          <li class="notes-list-item notes-list-item--case-study">
            <a href={`/ai/${item.slug}`}>
              <h3>{item.title}</h3>
              {item.metric && <p class="notes-list-metric">{item.metric}</p>}
            </a>
            <span class="notes-list-meta">
              <span class="notes-list-category">{item.domain}</span>
            </span>
          </li>
        ))}
      </ul>
    </section>

    <!-- ── Speaking ──────────────────────────────────────── -->
    <section id="speaking">
      <h2 class="section-title">Speaking</h2>
      <p class="section-desc">Talks, panels, and podcasts on AI product strategy.</p>
      <ul class="notes-list">
        {speaking.map((talk) => (
          <li class="notes-list-item">
            <a href={talk.href}>
              <h3>{talk.title}</h3>
            </a>
            <span class="notes-list-meta">
              <span class="notes-list-category">{talk.category}</span>
            </span>
          </li>
        ))}
      </ul>
      <!-- <p><a href="#speaking" class="view-all">View all speaking</a></p> -->
    </section>

    <!-- ── Connect CTA ───────────────────────────────────── -->
    <section id="about" class="connect-cta" aria-labelledby="connect-cta-title">
      <div class="connect-cta-inner">
        <h2 id="connect-cta-title" class="connect-cta-title">Let's connect</h2>
        <p class="connect-cta-text">
          I'm always up for conversations with builders and fellow AI-curious
          folks shipping real products. Say hi on LinkedIn.
        </p>
        <a
          href="https://www.linkedin.com/in/debajyoti-das-a265a938/"
          target="_blank"
          rel="noopener noreferrer"
          class="connect-cta-button"
        >
          <svg class="connect-cta-icon" viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" focusable="false">
            <path fill="currentColor" d="M20.45 20.45h-3.56v-5.57c0-1.33-.03-3.04-1.85-3.04-1.86 0-2.14 1.45-2.14 2.94v5.67H9.35V9h3.42v1.56h.05c.48-.9 1.65-1.85 3.39-1.85 3.62 0 4.29 2.38 4.29 5.48v6.26ZM5.34 7.43a2.07 2.07 0 1 1 0-4.14 2.07 2.07 0 0 1 0 4.14Zm1.78 13.02H3.56V9h3.56v11.45ZM22.22 0H1.77C.79 0 0 .77 0 1.72v20.56C0 23.23.79 24 1.77 24h20.45c.98 0 1.78-.77 1.78-1.72V1.72C24 .77 23.2 0 22.22 0Z"></path>
          </svg>
          <span>Connect with me on LinkedIn</span>
          <span class="connect-cta-arrow" aria-hidden="true">→</span>
        </a>
      </div>
    </section>

  </div>
</Layout>
